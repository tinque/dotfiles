# Open WezTerm
cmd + alt - return : open -na WezTerm

# Shottr screenshots (using Shottr's built-in hotkeys instead)
# 0x14 = physical "3" key, 0x15 = "4" key, 0x17 = "5" key
# cmd + shift - 0x14 : open "shottr://grab/fullscreen?then=copy"
# cmd + shift - 0x15 : open "shottr://grab/area?then=copy"
# cmd + shift - 0x17 : open "shottr://grab/window?then=copy"
