{
  "$schema": "https://opencode.ai/config.json",
  "model": "azure-cognitive-services/gpt-5.3-codex",
  "autoupdate": true,
  "provider": {
    "amazon-bedrock": {
      "options": {
        "region": "us-east-1",
        "profile": "sandbox",
      },
    },
    "azure-cognitive-services": {
      "options": {
        "resourceName": "coding-billabex-eastus2",
        "useCompletionUrls": false,
      },
    },
    "azure-custom": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Azure Custom",
      "options": {
        "baseURL": "https://coding-billabex-eastus2.openai.azure.com/openai/v1",
        "useCompletionUrls": true
      },
      "models": {
        "kimi-k2.5": {
          "id": "Kimi-K2.5",
          "name": "Kimi K2.5",
          "cost": {
            "input": 0.6,
            "output": 3,
          },
          "limit": {
            "context": 262144,
            "output": 262144,
          },
          "release_date": "2026-02-06",
          "variants": {},
        },
      },
    },
    "google-vertex": {
      "options": {
        "location": "global",
        "project": "billabex-sandbox-quentin-4d6c",
      },
    },
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
    },
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true,
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true,
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true,
    },
    "langsmith": {
      "type": "remote",
      "url": "https://langsmith-mcp-server.onrender.com/mcp",
      "enabled": true,
      "oauth": false,
      "headers": {
        "LANGSMITH-API-KEY": "{file:~/.config/opencode/secrets/langsmith_api_key}",
      },
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {file:~/.config/opencode/secrets/github_mcp_token}",
      },
      "enabled": true,
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--acceptInsecureCerts",
        "--experimentalScreencast",
        "--autoConnect",
      ],
    },
  },
  "plugin": [],
}
