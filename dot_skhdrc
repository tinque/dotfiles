# skhd configuration - Flameshot screenshot shortcuts
# Replaces macOS native Cmd+Shift+3/4/5 with Flameshot equivalents

# Full screen screenshot to clipboard
cmd + shift - 3 : /opt/homebrew/bin/flameshot full --clipboard

# Area selection screenshot to clipboard
cmd + shift - 4 : /opt/homebrew/bin/flameshot gui --clipboard

# Flameshot launcher panel
cmd + shift - 5 : /opt/homebrew/bin/flameshot launcher
